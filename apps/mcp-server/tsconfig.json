{
    "extends": "@workleap/typescript-configs/library.json",
    "exclude": ["dist", "node_modules"],
    "include": ["**/*", "../../types/*"],
    "compilerOptions": {
        "allowImportingTsExtensions": false,
        "module": "esnext",
        "moduleResolution": "Bundler",
        "outDir": "./dist",
        "paths": {
            "@docs/ai": [
                "./src/.docs/index.ts",
            ]
        },
    }
}
