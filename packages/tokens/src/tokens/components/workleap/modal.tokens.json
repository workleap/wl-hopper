{
    "comp-modal": {
        "background": {
            "$type": "color",
            "$value": "{neutral.surface}"
        },
        "border": {
            "$type": "border",
            "$value": "none"
        },
        "border-radius": {
            "$type": "borderRadius",
            "$value": "{shape.rounded-md}"
        },
        "backdrop-filter": {
